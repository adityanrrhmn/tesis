{
  "_comment": "TEMPLATE — salin ke .mcp.json lalu isi placeholder <...>. File .mcp.json asli (berisi kunci) diabaikan git; repo PUBLIK, jangan pernah commit kunci. Obsidian: isi key POLOS tanpa awalan 'Bearer' (client menambahkannya sendiri); samakan port/protokol dengan setelan plugin Local REST API (default vault ini: HTTP 27128). Sesuaikan path arxiv dengan lokasi clone di device Anda. Lihat 'SETUP MCP.md'.",
  "mcpServers": {
    "obsidian": {
      "command": "uvx",
      "args": ["mcp-obsidian"],
      "env": {
        "OBSIDIAN_API_KEY": "<API_KEY_DARI_PLUGIN_LOCAL_REST_API_TANPA_KATA_BEARER>",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27128",
        "OBSIDIAN_PROTOCOL": "http"
      }
    },
    "zotero": {
      "command": "uvx",
      "args": ["--from", "zotero-mcp-server", "zotero-mcp"],
      "env": { "ZOTERO_LOCAL": "true" }
    },
    "arxiv": {
      "command": "uvx",
      "args": ["arxiv-mcp-server[pdf]", "--storage-path", "C:\\DATA\\Thesis\\02 - Literatur\\PDF"]
    },
    "paper-search": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/openags/paper-search-mcp", "paper-search-mcp"],
      "env": { "PAPER_SEARCH_MCP_UNPAYWALL_EMAIL": "aijenteknologi@gmail.com" }
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": { "PYTHONIOENCODING": "utf-8" }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "huggingface": {
      "type": "http",
      "url": "https://huggingface.co/mcp",
      "headers": { "Authorization": "Bearer <HF_TOKEN_READ_DARI_huggingface.co/settings/tokens>" }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "CONTEXT7_API_KEY": "<API_KEY_DARI_context7.com/dashboard>" }
    }
  }
}
