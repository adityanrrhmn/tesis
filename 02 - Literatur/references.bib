% ============================================================
% Daftar referensi tesis (BibTeX) — gaya sitasi: APA-7 / penulis-tahun
%
% CATATAN PENTING:
% File ini = salinan kerja/master. Naskah LaTeX MEMBACA dari
% 'referensi.bib' di dalam folder proyek:
%   01 - Naskah/Tesis (LaTeX MKA)/referensi.bib
%   01 - Naskah/Proposal (LaTeX MKA)/referensi.bib
% Disarankan: atur Zotero (Better BibTeX) auto-export LANGSUNG ke
% file referensi.bib proyek LaTeX agar sitasi selalu sinkron.
%
% Tips:
% - Kunci sitasi konsisten: namabelakangTahunkatajudul  (mis. vaswani2017attention)
% - Untuk export otomatis dari Zotero, gunakan plugin "Better BibTeX"
%   dan arahkan auto-export ke file ini.
% - Claude dapat menambah entri ke sini saat kamu menemukan paper baru.
%
% Contoh format (hapus saat sudah ada entri asli):
% ============================================================

@article{contoh2024judul,
  author  = {Penulis, Pertama and Penulis, Kedua},
  title   = {Judul Artikel yang Direferensikan},
  journal = {Nama Jurnal},
  year    = {2024},
  volume  = {12},
  number  = {3},
  pages   = {45--67},
  doi     = {10.0000/contoh.doi}
}

% @inproceedings{...}   % untuk makalah konferensi
% @book{...}            % untuk buku
% @misc{...}            % untuk arXiv / pracetak / sumber web
